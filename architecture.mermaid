graph TB
    subgraph "User Device - Progressive Web App"
        UI[User Interface<br/>React 19.2 + Vite 7.3 + Tailwind CSS v4]
        UI --> VoiceQA[Voice Safety Q&A<br/>Web Speech API STT]
        UI --> HazardCam[Hazard Detection<br/>Camera / Upload]
        UI --> JHA[JHA Safety Checklists<br/>8 Templates]
        UI --> Profile[User Profile<br/>& Govt Schemes]

        VoiceQA --> Services[Service Layer<br/>Axios HTTP Client]
        HazardCam --> Services
        JHA --> Services
        Profile --> LocalStore[localStorage<br/>Offline Persistence]

        Services --> TTS[Text-to-Speech<br/>Polly Primary + Browser Fallback]
        Services --> ActivityTracker[Activity Tracker<br/>Recent Activity Logging]

        UI --> SW[Service Worker<br/>Offline Caching + PWA Install]
    end

    Services -->|HTTPS| CloudFront[Amazon CloudFront<br/>CDN + HTTPS + Gzip<br/>India Edge Locations]

    subgraph "AWS Cloud - ap-south-1 Mumbai"
        CloudFront --> S3[Amazon S3<br/>krishirakshak-frontend<br/>Static PWA Hosting]

        CloudFront -->|API Requests| APIGW[Amazon API Gateway<br/>REST API + CORS]

        APIGW -->|POST /ask-safety-question| LambdaQA[Lambda: ask-safety<br/>Node.js 18 ES Modules]
        APIGW -->|POST /analyze-hazards| LambdaHazard[Lambda: analyze-hazards<br/>Node.js 18 ES Modules]
        APIGW -->|POST /text-to-speech| LambdaTTS[Lambda: text-to-speech<br/>Node.js 18 ES Modules]

        LambdaQA --> KB[Bedrock Knowledge Bases<br/>KB: PIMCAVAB8S<br/>17+ Official Documents]
        KB --> OpenSearch[OpenSearch Serverless<br/>Vector Store]
        KB --> TitanEmbed[Titan Text Embeddings V2<br/>Document Vectors]
        LambdaQA --> Bedrock[Amazon Bedrock<br/>Nova Lite apac.amazon.nova-lite-v1:0<br/>Converse API]

        LambdaHazard --> Rekognition[Amazon Rekognition<br/>DetectLabels<br/>20 Labels / 50%+ Confidence]
        LambdaHazard --> Bedrock

        LambdaTTS --> Polly[Amazon Polly<br/>Hindi: Aditi Standard<br/>English: Kajal Neural]

        LambdaQA --> DynamoDB[(Amazon DynamoDB<br/>krishirakshak-activity-log)]
        LambdaHazard --> DynamoDB

        LambdaQA --> CloudWatch[Amazon CloudWatch<br/>Monitoring & Logs]
        LambdaHazard --> CloudWatch
        LambdaTTS --> CloudWatch
    end

    subgraph "RAG Document Sources"
        KB -.-> ICAR[ICAR Guidelines]
        KB -.-> FSSAI[FSSAI Standards]
        KB -.-> InsecticideAct[Insecticides Act 1968]
        KB -.-> NDMA[NDMA Safety Protocols]
        KB -.-> NFSM[NFSM Publications]
    end

    style UI fill:#e1f5ff
    style Services fill:#fff4e1
    style SW fill:#f0e1ff
    style CloudFront fill:#e1ffe1
    style APIGW fill:#e1ffe1
    style LambdaQA fill:#ffe1e1
    style LambdaHazard fill:#ffe1e1
    style LambdaTTS fill:#ffe1e1
    style DynamoDB fill:#ffe1f0
    style S3 fill:#e1f0ff
    style Bedrock fill:#ffe8cc
    style KB fill:#ffe8cc
    style Rekognition fill:#ffe8cc
    style Polly fill:#ffe8cc
    style OpenSearch fill:#ffe8cc
